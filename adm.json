{
  "runtime": {
    "progress_log": "_progress_log.md",
    "temp_dir": ".temp",
    "uv_cache_dir": ".uv_cache",
    "cmd_runner": "",
    "demos_enabled": false
  },
  "delphi": {
    "bds": "",
    "platform": "Win64",
    "profile": ""
  },
  "rag": {
    "db_dir": "logs/rag",
    "include_globs": [
      "**/*.py",
      "**/*.md",
      "**/*.mdx",
      "**/*.txt",
      "**/*.csv",
      "**/*.toml",
      "**/*.json",
      "**/*.xml",
      "**/*.yaml",
      "**/*.yml",
      "**/*.ps1",
      "**/*.cmd",
      "**/*.pas",
      "**/*.pdf",
      "**/*.docx",
      "**/*.pptx",
      "**/*.xlsx",
      "**/*.c",
      "**/*.cpp",
      "**/*.css",
      "**/*.go",
      "**/*.h",
      "**/*.hpp",
      "**/*.html",
      "**/*.java",
      "**/*.js",
      "**/*.mjs",
      "**/*.kt",
      "**/*.php",
      "**/*.rb",
      "**/*.rs",
      "**/*.swift",
      "**/*.ts",
      "**/*.tsx",
      "**/*.svelte",
      "**/*.vue"
    ],
    "add_patterns": [],
    "exclude_globs": [
      "**/.git/**",
      "**/.venv/**",
      "**/.venv_wsl/**",
      "**/build/**",
      "**/dist/**",
      "**/releases/**",
      "**/logs/**",
      "**/.temp/**",
      "**/.uv_cache/**"
    ],
    "exclude_patterns": [],
    "max_file_bytes": 2000000,
    "chunk_lines": 120,
    "chunk_overlap_lines": 20,
    "top_k": 8,
    "vector_top_k": 160,
    "fts_top_k": 160,
    "dq_top_k": 160,
    "weight_vector": 1.0,
    "weight_fts": 1.0,
    "weight_dq": 1.0,
    "rrf_k": 60,
    "dq_rerank_window": 48,
    "dq_projection_dim": 2048,
    "dq_keep_rows": 6,
    "dq_keep_cols": 6,
    "dq_include_energy": true,
    "dq_structure_weight": 0.12,
    "dq_residual_weight": 0.05,
    "astgrep_tags_enabled": false,
    "adid_history_enabled": true,
    "cmd_runner_logs_enabled": true,
    "embed": {
      "backend": "sentence_transformers",
      "model": "BAAI/bge-m3",
      "device": "auto",
      "batch_size": 16,
      "normalize": true
    }
  }
}
